{
  "name": "sentiment-analysis",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c cyan.bold,magenta.bold \"uv run python backend/app.py\" \"pnpm --filter @sentiment-analysis/frontend dev\"",
    "dev:backend": "uv run python backend/app.py",
    "dev:frontend": "pnpm --filter @sentiment-analysis/frontend dev",
    "build": "pnpm --filter @sentiment-analysis/frontend build",
    "preview": "pnpm --filter @sentiment-analysis/frontend preview",
    "check": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "concurrently": "^9.0.0"
  }
}
